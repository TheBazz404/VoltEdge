{
	"info": {
		"name": "VoltEdge MVP",
		"description": "Happy Path: SessionStarted → SessionValidated → SessionRated → InvoiceLineCreated\n\nBase URL variabel: sæt `base_url` til din Azure URL eller http://localhost:8000",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://voltedge-app-fqgdacaadyd9axds.germanywestcentral-01.azurewebsites.net"
		},
		{
			"key": "session_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "1. Health — Alle services",
			"item": [
				{
					"name": "GET /health",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Healthy', () => pm.expect(pm.response.json().status).to.eql('healthy'));"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/health"
					}
				},
				{
					"name": "GET /sessions/health",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/sessions/health"
					}
				},
				{
					"name": "GET /billing/health",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/billing/health"
					}
				},
				{
					"name": "GET /analytics/health",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/analytics/health"
					}
				}
			]
		},
		{
			"name": "2. Session — Happy Path",
			"item": [
				{
					"name": "POST /sessions/start",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('session_id', jsonData.session_id);",
									"console.log('Session ID: ' + jsonData.session_id);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"charger_id\": \"charger-1\",\n  \"contract_id\": \"contract-1\"\n}"
						},
						"url": "{{base_url}}/sessions/start"
					}
				},
				{
					"name": "POST /sessions/{session_id}/authorize",
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{base_url}}/sessions/{{session_id}}/authorize"
					}
				},
				{
					"name": "POST /sessions/{session_id}/start-charging",
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{base_url}}/sessions/{{session_id}}/start-charging"
					}
				},
				{
					"name": "POST /sessions/{session_id}/complete",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"energy_delivered\": 25.5,\n  \"duration_minutes\": 60\n}"
						},
						"url": "{{base_url}}/sessions/{{session_id}}/complete"
					}
				}
			]
		},
		{
			"name": "3. Billing — Rating & Invoice",
			"item": [
				{
					"name": "POST /billing/rate",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"energy_delivered\": 25.5,\n  \"duration_minutes\": 60,\n  \"charger_id\": \"charger-1\",\n  \"contract_id\": \"contract-1\"\n}"
						},
						"url": "{{base_url}}/billing/rate"
					}
				},
				{
					"name": "POST /billing/invoice",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"total_cost\": 92.50,\n  \"currency\": \"DKK\",\n  \"breakdown\": {\n    \"energy\": 62.50,\n    \"parking\": 30.0\n  }\n}"
						},
						"url": "{{base_url}}/billing/invoice"
					}
				}
			]
		},
		{
			"name": "4. Analytics — ML",
			"item": [
				{
					"name": "POST /analytics/predict",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"duration_minutes\": 60\n}"
						},
						"url": "{{base_url}}/analytics/predict"
					}
				},
				{
					"name": "POST /analytics/detect",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"energy_delivered\": 2.0,\n  \"duration_minutes\": 60\n}"
						},
						"url": "{{base_url}}/analytics/detect"
					}
				}
			]
		}
	]
}
